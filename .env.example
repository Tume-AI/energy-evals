# EnergyEvals environment configuration template.
# Copy to .env and fill in your credentials:  cp .env.example .env

# --- LLM Provider (required) ---
# OpenRouter fronts OpenAI, Anthropic, Google, DeepSeek, and more behind one API.
OPENROUTER_API_KEY=sk-or-...

# --- Tools (optional; each enables specific functionality) ---
EXA_API_KEY=                      # SearchTool (also covers document retrieval)
GRIDSTATUS_API_KEY=               # GridStatusAPITool
OPENWEATHER_API_KEY=              # OpenWeatherTool
OPEN_EI_API_KEY=                  # TariffsTool
RENEWABLES_NINJA_API_KEY=         # RenewablesTool

# --- Database tool (optional; enables DatabaseTool's direct PostgreSQL access) ---
DB_HOST=                          # e.g. db.example.com
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_POOL_MIN=1
DB_POOL_MAX=5
# DB_TABLES_JSON=                 # optional: override path to table-descriptions JSON
